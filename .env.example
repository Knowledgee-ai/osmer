# Database (Neon Postgres). The app connects as a non-BYPASSRLS role
# (typically `osmer_app`) so row-level security policies actually fire.
# The owner connection is only used for migrations / role provisioning.
DATABASE_URL=postgresql://osmer_app:password@host/knowledgee?sslmode=require
DATABASE_URL_OWNER=postgresql://neondb_owner:owner_password@host/knowledgee?sslmode=require

# Used by scripts/setup-app-role.ts when first provisioning osmer_app
APP_ROLE_PASSWORD=generate-a-random-password-here

# Auth
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# AI Model Providers
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_GENERATIVE_AI_API_KEY=xxx
XAI_API_KEY=xxx

# Knowledge Extraction (uses a cheap model)
EXTRACTION_MODEL=openai/gpt-4o-mini
